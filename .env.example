# ============================================================================
# OpenFi - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_NAME=OpenFi
APP_ENV=development  # Options: development, staging, production
DEBUG=true           # Set to false in production
LOG_LEVEL=INFO       # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Web Backend
WEB_BACKEND_HOST=0.0.0.0
WEB_BACKEND_PORT=8686

# ----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------------------------------------------
DB_USER=openfi
DB_PASSWORD=openfi_password  # CHANGE IN PRODUCTION
DB_HOST=localhost                # Use 'postgres' when running in Docker
DB_PORT=5432
DB_NAME=openfi

# Database connection pooling
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# Full database URL (auto-constructed if not provided)
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0  # Use 'redis://redis:6379/0' in Docker
REDIS_PASSWORD=                      # Leave empty for no password

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# IMPORTANT: Generate strong random keys for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"

SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ----------------------------------------------------------------------------
# External Data Sources
# ----------------------------------------------------------------------------
# Economic Calendar
FOREXFACTORY_API_KEY=

# Market Data
ALPHAVANTAGE_API_KEY=

# News APIs
NEWSAPI_KEY=

# Social Media
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# Academic Papers
SSRN_API_KEY=

# Search API
SERPAPI_KEY=

# ----------------------------------------------------------------------------
# LLM Providers
# ----------------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4  # Options: gpt-4, gpt-3.5-turbo

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-20240229

# Local LLM (Ollama or similar)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama2

# ----------------------------------------------------------------------------
# Vector Database Configuration
# ----------------------------------------------------------------------------
VECTOR_DB_PROVIDER=pinecone  # Options: pinecone, weaviate, qdrant

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=openfi-vectors

# Weaviate (alternative)
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=

# Qdrant (alternative)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ----------------------------------------------------------------------------
# Push Notification Channels
# ----------------------------------------------------------------------------
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord
DISCORD_WEBHOOK_URL=

# Feishu/Lark
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# WeChat Work
WECHAT_WORK_WEBHOOK_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ----------------------------------------------------------------------------
# Trading Broker Configuration
# ----------------------------------------------------------------------------
# MetaTrader 4
MT4_SERVER=
MT4_LOGIN=
MT4_PASSWORD=

# MetaTrader 5
MT5_SERVER=
MT5_LOGIN=
MT5_PASSWORD=

# TradingView (if applicable)
TRADINGVIEW_USERNAME=
TRADINGVIEW_PASSWORD=

# ----------------------------------------------------------------------------
# Monitoring and Metrics
# ----------------------------------------------------------------------------
PROMETHEUS_PORT=8001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin  # CHANGE IN PRODUCTION

# Alert webhook for critical notifications
ALERT_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_FILE_PATH=logs/openfi.log
LOG_MAX_BYTES=104857600  # 100MB
LOG_BACKUP_COUNT=10
LOG_RETENTION_DAYS=30

# ----------------------------------------------------------------------------
# Backup and Disaster Recovery
# ----------------------------------------------------------------------------
BACKUP_STORAGE_TYPE=local  # Options: local, s3, gcs, azure

# Local backup
BACKUP_LOCAL_PATH=backups

# AWS S3 backup
AWS_S3_BACKUP_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud Storage backup
GCS_BACKUP_BUCKET=
GCS_PROJECT_ID=
GCS_CREDENTIALS_FILE=

# Azure Blob Storage backup
AZURE_BACKUP_CONTAINER=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=

# Backup settings
BACKUP_ENCRYPTION_ENABLED=true
WAL_ARCHIVING_ENABLED=true

# ----------------------------------------------------------------------------
# Performance and Optimization
# ----------------------------------------------------------------------------
# Cache TTL in seconds
CACHE_TTL=300

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ----------------------------------------------------------------------------
# Time Series Database (Optional)
# ----------------------------------------------------------------------------
TIMESERIES_URL=postgresql+asyncpg://user:password@localhost:5432/openfi_timeseries

# ----------------------------------------------------------------------------
# Development and Testing
# ----------------------------------------------------------------------------
# Set to true to enable test mode (uses in-memory databases)
TEST_MODE=false

# Enable SQL query logging (verbose, use only in development)
SQL_ECHO=false

# ============================================================================
# End of Configuration
# ============================================================================
